---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Carte de visite – Fabienne Luciani">
  <div class="page">
    <div class="screen-header">
      <h1>Carte de visite</h1>
      <p>Format standard 85 × 55 mm — <button onclick="window.print()">Imprimer</button></p>
    </div>

    <div class="preview">
      <!-- RECTO -->
      <div class="card recto">
        <div class="card-bg-deco"></div>
        <div class="card-content">
          <div class="top">
            <p class="eyebrow">Kinésiologue &amp; Maître Reiki</p>
            <h2>Fabienne<br /><em>Luciani</em></h2>
          </div>
          <div class="bottom">
            <div class="contact-line">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="11" height="11">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <span>06 33 73 87 64</span>
            </div>
            <div class="contact-line">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="11" height="11">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>Fayence, Var (83)</span>
            </div>
            <div class="contact-line">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="11" height="11">
                <circle cx="12" cy="12" r="10"/>
                <line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              <span>www.fabienneluciani.fr</span>
            </div>
          </div>
        </div>
        <div class="gold-bar"></div>
      </div>

      <!-- VERSO -->
      <div class="card verso">
        <div class="verso-bg"></div>
        <div class="verso-content">
          <div class="monogram">FL</div>
          <p class="tagline">
            &laquo;&nbsp;Un espace de soin,<br />d'écoute et d'équilibre.&nbsp;&raquo;
          </p>
          <div class="deco-line">
            <span>✦</span>
          </div>
          <p class="verso-subtitle">Kinésiologie &amp; Reiki</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* ── Page wrapper ─────────────────────────────────────────── */
  .page {
    min-height: 100vh;
    background: #EFEFEC;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    gap: 2rem;
  }

  .screen-header {
    text-align: center;
  }

  .screen-header h1 {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    color: var(--color-green-dark);
    margin-bottom: 0.5rem;
  }

  .screen-header p {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .screen-header button {
    background: var(--color-green);
    color: #fff;
    border: none;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    border-radius: 2px;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: background 0.2s;
  }

  .screen-header button:hover {
    background: var(--color-green-dark);
  }

  .preview {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
    align-items: center;
    justify-content: center;
  }

  /* ── Card base ─────────────────────────────────────────────── */
  /* 85mm × 55mm at 96dpi ≈ 321px × 208px — on screen we scale 1.5× */
  .card {
    width: 321px;
    height: 208px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.18);
    border-radius: 3px;
    flex-shrink: 0;
  }

  /* ── RECTO ─────────────────────────────────────────────────── */
  .recto {
    background: var(--color-white);
  }

  .card-bg-deco {
    position: absolute;
    top: -40px;
    right: -40px;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: var(--color-green-pale);
    opacity: 0.7;
  }

  .card-bg-deco::after {
    content: '';
    position: absolute;
    bottom: -60px;
    left: -80px;
    width: 130px;
    height: 130px;
    border-radius: 50%;
    background: var(--color-gold-light);
    opacity: 0.35;
  }

  .gold-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(to bottom, var(--color-gold), var(--color-green-light));
  }

  .card-content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 18px 18px 16px 24px;
  }

  .eyebrow {
    font-size: 7px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 6px;
    font-family: var(--font-sans);
    font-weight: 400;
  }

  .card-content h2 {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-green-dark);
  }

  .card-content h2 em {
    font-style: italic;
    color: var(--color-green);
  }

  .bottom {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .contact-line {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--color-text-light);
  }

  .contact-line svg {
    color: var(--color-green);
    flex-shrink: 0;
  }

  .contact-line span {
    font-size: 8.5px;
    font-family: var(--font-sans);
    font-weight: 300;
    letter-spacing: 0.03em;
  }

  /* ── VERSO ─────────────────────────────────────────────────── */
  .verso {
    background: var(--color-green-dark);
  }

  .verso-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(201,169,110,0.18) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(168,197,160,0.15) 0%, transparent 55%);
  }

  .verso-content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 20px;
    text-align: center;
  }

  .monogram {
    font-family: var(--font-serif);
    font-size: 34px;
    font-weight: 300;
    color: var(--color-gold-light);
    letter-spacing: 0.12em;
    line-height: 1;
    margin-bottom: 2px;
  }

  .tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 9.5px;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
  }

  .deco-line {
    color: var(--color-gold);
    font-size: 10px;
    opacity: 0.7;
    letter-spacing: 0.3em;
  }

  .verso-subtitle {
    font-size: 7px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold-light);
    opacity: 0.7;
    font-family: var(--font-sans);
    font-weight: 300;
  }

  /* ── Print ─────────────────────────────────────────────────── */
  @media print {
    .screen-header { display: none; }

    .page {
      background: white;
      padding: 0;
      min-height: unset;
    }

    .preview {
      gap: 8mm;
      padding: 10mm;
    }

    /* Forcer les dimensions réelles à l'impression */
    .card {
      width: 85mm;
      height: 55mm;
      box-shadow: none;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .card-content h2 {
      font-size: 20pt;
    }

    .eyebrow { font-size: 5.5pt; }
    .contact-line span { font-size: 7.5pt; }
    .monogram { font-size: 26pt; }
    .tagline { font-size: 7pt; }
    .verso-subtitle { font-size: 5.5pt; }
  }
</style>
