---
---

<footer>
  <div class="container">
    <div class="brand">
      <p class="name">Fabienne Luciani</p>
      <p class="tagline">Kinésiologue &amp; Maître Reiki — Fayence</p>
    </div>
    <div class="links">
      <a href="#a-propos">À propos</a>
      <a href="#services">Services</a>
      <a href="#contact">Contact</a>
    </div>
    <p class="copy">&copy; {new Date().getFullYear()} Fabienne Luciani. Tous droits réservés.</p>
  </div>
</footer>

<style>
  footer {
    background: var(--color-green-dark);
    padding: 3rem 2rem;
    color: rgba(255,255,255,0.75);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .name {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 0.3rem;
  }

  .tagline {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold-light);
    opacity: 0.8;
  }

  .links {
    display: flex;
    gap: 2.5rem;
  }

  .links a {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    transition: color 0.2s;
  }

  .links a:hover {
    color: var(--color-gold-light);
  }

  .copy {
    font-size: 0.75rem;
    opacity: 0.45;
  }
</style>
